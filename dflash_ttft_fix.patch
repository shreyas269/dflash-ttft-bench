new file mode 100644
index 000000000..d43ef26e4
--- /dev/null
+++ b/vllm/v1/spec_decode/dflash_kv_precompute.py
@@ -0,0 +1,211 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Fused Triton kernel for DFlash draft-side context KV precomputation.
+
+DFlash populates the draft KV cache with K/V computed from the target model's
+hidden states before each draft forward pass. During prefill this is done on
+the full prompt (or the un-cached suffix when prefix caching is enabled), and
+with the original implementation it runs as a long chain of eager ops:
+
+    hidden_norm -> F.linear(fused KV proj) -> permute+contiguous
+        -> per-layer RMSNorm(K)   (L kernel launches)
+        -> global RoPE            (positions.repeat(L))
+        -> per-layer cache insert (L kernel launches)
+
+For a long prefill this path dominates TTFT because:
+  * the `permute(...).contiguous()` materializes a [2, L, num_ctx, nkv, hd]
+    tensor (hundreds of MB for a >=8K prefill),
+  * an equally-large `empty_like(all_k)` is allocated for the K norm output,
+  * `positions.repeat(L)` grows the RoPE position tensor by a factor of L.
+
+The kernel defined here fuses `RMSNorm(K) + RoPE(K) + store K/V` into a single
+pass per layer. It reads K/V tiles directly from the fused F.linear output
+(using strided indexing) and writes the results into pre-allocated staging
+buffers of shape [num_ctx, num_kv_heads, head_dim]. The staging buffers are
+then handed to the backend's existing `do_kv_cache_update`, which knows how to
+write into every cache layout the project supports (including fp8).
+
+The upstream sglang DFlash port uses the same fused-norm-plus-RoPE approach
+(see python/sglang/srt/speculative/triton_ops/fused_kv_materialize.py).
+"""
+
+from __future__ import annotations
+
+import torch
+
+from vllm.triton_utils import tl, triton
+
+
+@triton.jit
+def _dflash_fused_k_norm_rope_kernel(
+    # Source: fused F.linear output viewed as [num_ctx, L, 2, num_kv_heads, head_dim]
+    kv_fused_ptr,
+    kv_fused_stride_ctx,  # elements per ctx row (= L * 2 * num_kv_heads * head_dim)
+    layer_elem_offset,  # runtime offset into the ctx row selecting this layer
+    # Per-layer K norm weight [head_dim]
+    k_norm_weight_ptr,
+    # RoPE cos/sin table [max_pos, rotary_dim]
+    cos_sin_cache_ptr,
+    cos_sin_stride_pos,
+    # Absolute positions [num_ctx]
+    positions_ptr,
+    # Destination staging buffers [num_ctx, num_kv_heads, head_dim]
+    k_out_ptr,
+    v_out_ptr,
+    k_out_stride_ctx,
+    k_out_stride_head,
+    v_out_stride_ctx,
+    v_out_stride_head,
+    num_ctx,
+    num_kv_heads: tl.constexpr,
+    head_dim: tl.constexpr,
+    rotary_dim: tl.constexpr,
+    half_rotary_dim: tl.constexpr,
+    eps: tl.constexpr,
+    IS_NEOX: tl.constexpr,
+    BLOCK_HD: tl.constexpr,
+):
+    """Fused RMSNorm(K) + RoPE(K) + store K/V for one attention layer.
+
+    Grid: (num_ctx, num_kv_heads). Each program handles one (ctx, head) slice
+    of width `head_dim` and writes one row of both K and V to the staging
+    buffers.
+    """
+    ctx_id = tl.program_id(0)
+    head_id = tl.program_id(1)
+    if ctx_id >= num_ctx:
+        return
+
+    # Base pointer for this (ctx, layer, head) K tile in the fused projection.
+    row_base = kv_fused_ptr + ctx_id * kv_fused_stride_ctx + layer_elem_offset
+    k_base = row_base + head_id * head_dim
+    # V for the same (ctx, layer, head) sits one "KV slot" after K.
+    v_base = k_base + num_kv_heads * head_dim
+
+    offs = tl.arange(0, BLOCK_HD)
+    mask_hd = offs < head_dim
+    mask_half = offs < half_rotary_dim
+
+    # ---- RMSNorm(K) across head_dim ----
+    k_raw = tl.load(k_base + offs, mask=mask_hd, other=0.0).to(tl.float32)
+    var = tl.sum(k_raw * k_raw) / head_dim
+    inv_rms = tl.rsqrt(var + eps)
+    w = tl.load(k_norm_weight_ptr + offs, mask=mask_hd, other=1.0).to(tl.float32)
+    k_normed = k_raw * inv_rms * w
+
+    # V passes through unchanged (no norm, no rotation).
+    v_raw = tl.load(v_base + offs, mask=mask_hd, other=0.0)
+
+    # ---- RoPE(K) ----
+    # We only support neox-style RoPE for the fused path, matching the
+    # validation done by DFlashQwen3Model._build_fused_kv_buffers. For heads
+    # where `rotary_dim < head_dim` the trailing slice is left untouched.
+    position = tl.load(positions_ptr + ctx_id)
+    cos_base = cos_sin_cache_ptr + position * cos_sin_stride_pos
+    cos_v = tl.load(cos_base + offs, mask=mask_half, other=1.0).to(tl.float32)
+    sin_v = tl.load(
+        cos_base + half_rotary_dim + offs, mask=mask_half, other=0.0
+    ).to(tl.float32)
+
+    # first half of k_normed (already in register) and second half (load+norm)
+    k_first = tl.where(mask_half, k_normed, 0.0)
+    k_second_raw = tl.load(k_base + half_rotary_dim + offs, mask=mask_half, other=0.0).to(
+        tl.float32
+    )
+    w_second = tl.load(
+        k_norm_weight_ptr + half_rotary_dim + offs, mask=mask_half, other=1.0
+    ).to(tl.float32)
+    k_second_normed = k_second_raw * inv_rms * w_second
+
+    if IS_NEOX:
+        k_rot_first = k_first * cos_v - k_second_normed * sin_v
+        k_rot_second = k_second_normed * cos_v + k_first * sin_v
+    else:
+        # Only neox is exercised today; GPT-J interleaved layout is rejected
+        # by the caller, so this branch only exists to keep the kernel
+        # specialisable for future backends.
+        k_rot_first = k_first
+        k_rot_second = k_second_normed
+
+    # ---- Store K ----
+    k_write = k_out_ptr + ctx_id * k_out_stride_ctx + head_id * k_out_stride_head
+    # Rotated halves
+    tl.store(k_write + offs, k_rot_first.to(v_raw.dtype), mask=mask_half)
+    tl.store(
+        k_write + half_rotary_dim + offs,
+        k_rot_second.to(v_raw.dtype),
+        mask=mask_half,
+    )
+    # Pass-through tail for heads where rotary_dim < head_dim.
+    if rotary_dim < head_dim:
+        mask_pass = (offs >= rotary_dim) & mask_hd
+        tl.store(k_write + offs, k_normed.to(v_raw.dtype), mask=mask_pass)
+
+    # ---- Store V (no transform) ----
+    v_write = v_out_ptr + ctx_id * v_out_stride_ctx + head_id * v_out_stride_head
+    tl.store(v_write + offs, v_raw, mask=mask_hd)
+
+
+def dflash_fused_k_norm_rope(
+    kv_fused: torch.Tensor,  # [num_ctx, L, 2, num_kv_heads, head_dim] view
+    layer_idx: int,
+    k_norm_weight: torch.Tensor,  # [head_dim]
+    cos_sin_cache: torch.Tensor,  # [max_pos, rotary_dim]
+    positions: torch.Tensor,  # [num_ctx]
+    k_out: torch.Tensor,  # [num_ctx, num_kv_heads, head_dim], contiguous
+    v_out: torch.Tensor,  # [num_ctx, num_kv_heads, head_dim], contiguous
+    *,
+    rotary_dim: int,
+    eps: float,
+    is_neox: bool,
+) -> None:
+    """Launch the fused K-norm + RoPE + V pass-through kernel for one layer.
+
+    `kv_fused` is the output of the fused KV linear projection, reshaped to
+    [num_ctx, num_layers, 2, num_kv_heads, head_dim]. `layer_idx` selects the
+    slice to process. `k_out` and `v_out` are expected to be pre-allocated
+    contiguous scratch buffers sized for the current `num_ctx`.
+    """
+    num_ctx = kv_fused.shape[0]
+    num_kv_heads = kv_fused.shape[3]
+    head_dim = kv_fused.shape[4]
+    if num_ctx == 0:
+        return
+    if rotary_dim <= 0 or rotary_dim > head_dim or rotary_dim % 2 != 0:
+        raise ValueError(
+            "Invalid rotary/head dim pair for DFlash fused precompute: "
+            f"rotary_dim={rotary_dim}, head_dim={head_dim}."
+        )
+
+    if positions.dtype != torch.int64:
+        positions = positions.to(torch.int64)
+
+    # Layer offset in elements: layer_idx * (2 * num_kv_heads * head_dim)
+    layer_elem_offset = layer_idx * 2 * num_kv_heads * head_dim
+
+    BLOCK_HD = triton.next_power_of_2(head_dim)
+    half_rotary_dim = rotary_dim // 2
+
+    _dflash_fused_k_norm_rope_kernel[(num_ctx, num_kv_heads)](
+        kv_fused,
+        kv_fused.stride(0),
+        layer_elem_offset,
+        k_norm_weight,
+        cos_sin_cache,
+        cos_sin_cache.stride(0),
+        positions,
+        k_out,
+        v_out,
+        k_out.stride(0),
+        k_out.stride(1),
+        v_out.stride(0),
+        v_out.stride(1),
+        num_ctx,
+        num_kv_heads=num_kv_heads,
+        head_dim=head_dim,
+        rotary_dim=rotary_dim,
+        half_rotary_dim=half_rotary_dim,
+        eps=eps,
+        IS_NEOX=is_neox,
+        BLOCK_HD=BLOCK_HD,
+    )
